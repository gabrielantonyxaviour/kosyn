{
  "app": {
    "name": "Kosyn AI",
    "description": "HIPAA-compliant Electronic Health Record system on Chainlink CRE. Patients own health data, providers access with consent, AI analyzes records inside TEE enclaves.",
    "version": "0.1.0",
    "techStack": {
      "framework": "Next.js 15 (App Router)",
      "language": "TypeScript",
      "auth": "Thirdweb Connect (email/social for patients, MetaMask for providers)",
      "ui": "shadcn/ui + Tailwind CSS v4",
      "stateManagement": "React Query + React useState",
      "ai": "Nillion nilAI — Gemma 3 27B (app-level + CRE TEE, cryptographic proof via secp256k1 signature)",
      "blockchain": "Foundry (Solidity ^0.8.19), Thirdweb SDK v5",
      "storage": "IPFS via Pinata (encrypted blobs)",
      "payments": "Stripe + KosynUSD (ERC-20)",
      "transcription": "AssemblyAI (realtime WebSocket)",
      "testing": "Foundry (contracts), Playwright (e2e)"
    }
  },
