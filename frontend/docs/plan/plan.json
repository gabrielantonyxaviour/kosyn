  "flows": [
    {
      "id": "patient-record-upload",
      "name": "Patient Uploads Health Record",
      "trigger": "user_action",
      "priority": "critical",
      "module": "patient",
      "outcome": "Record encrypted in TEE, stored on IPFS, hash registered on-chain",
      "tags": ["record", "encryption", "ipfs", "cre"],
      "steps": [
        {
          "order": 1,
          "screen": "patient.records",
          "description": "Patient clicks 'Upload Record' button",
          "checks": ["Upload button visible", "User authenticated via Thirdweb"]
        },
        {
          "order": 2,
          "endpoint": "cre.workflow-trigger",
          "description": "POST /api/cre/record-upload with patient data",
          "checks": ["Request payload contains patientData"]
        },
        {
          "order": 3,
          "service": "CRE TEE",
          "description": "CRE encrypts data with AES-256-GCM inside TEE, uploads to IPFS via Pinata",
          "checks": ["Encryption happens inside enclave"]
        },
        {
          "order": 4,
          "contract": "contracts.health-record-registry",
          "description": "CRE Forwarder calls onReport with opcode 0x00, stores IPFS CID on-chain",
          "checks": ["RecordUploaded event emitted", "recordCount incremented"]
        },
        {
          "order": 5,
          "screen": "patient.records",
          "description": "UI shows success toast, new record appears in grid",
          "checks": ["Toast shown", "Record card rendered with CID"]
        }
      ]
    },
    {
      "id": "provider-registration",
      "name": "Provider Registers with License Verification",
      "trigger": "user_action",
      "priority": "critical",
      "module": "provider",
      "outcome": "Provider verified in TEE and registered on-chain",
      "tags": ["provider", "registration", "cre", "verification"],
      "steps": [
        {
          "order": 1,
          "screen": "provider.register",
          "description": "Provider fills registration form (name, specialty, license, fee)",
          "checks": ["All required fields filled"]
        },
        {
          "order": 2,
          "endpoint": "cre.workflow-trigger",
          "description": "POST /api/cre/provider-registration with form data",
          "checks": [
            "Request contains name, specialty, jurisdiction, licenseNumber, fee"
          ]
        },
        {
          "order": 3,
          "service": "CRE TEE",
          "description": "CRE verifies license hash inside TEE enclave",
          "checks": ["Verification runs in confidential compute"]
        },
        {
          "order": 4,
          "contract": "contracts.provider-registry",
          "description": "CRE Forwarder calls onReport with opcode 0x03, stores Provider struct",
          "checks": ["ProviderRegistered event emitted"]
        },
        {
          "order": 5,
          "screen": "provider.register",
          "description": "CreFeed shows workflow completion, success toast",
          "checks": ["All CRE steps shown as done"]
        }
      ]
    },
    {
      "id": "consultation-booking",
      "name": "Patient Books Consultation",
      "trigger": "user_action",
      "priority": "high",
      "module": "patient",
      "outcome": "Consultation booked and paid via KUSD or Stripe",
      "tags": ["booking", "payment", "stripe", "kusd"],
      "steps": [
        {
          "order": 1,
          "screen": "patient.dashboard",
          "description": "Patient clicks 'Book Consultation'",
          "checks": ["Button navigates to /book"]
        },
        {
          "order": 2,
          "screen": "patient.book",
          "description": "Patient selects doctor from DoctorPicker grid",
          "checks": ["Doctor card highlighted on selection"]
        },
        {
          "order": 3,
          "screen": "patient.book",
          "description": "Patient picks date and time slot from CalendarPicker",
          "checks": [
            "Past dates disabled",
            "Time slots shown after date selection"
          ]
        },
        {
          "order": 4,
          "screen": "patient.book",
          "description": "Patient pays via KUSD (mock) or Stripe checkout",
          "checks": ["Payment method toggle works", "KUSD shows balance check"]
        },
        {
          "order": 5,
          "endpoint": "payments.stripe-checkout",
          "description": "If Stripe: POST /api/stripe/checkout creates session, redirects to Stripe",
          "checks": ["Stripe session URL returned"]
        },
        {
          "order": 6,
          "screen": "patient.book",
          "description": "Confirmation dialog shows booking details",
          "checks": ["Dialog opens with doctor name"]
        }
      ]
    },
    {
      "id": "consultation-session-patient",
      "name": "Patient Consultation Session",
      "trigger": "navigation",
      "priority": "critical",
      "module": "consultation",
      "outcome": "Patient approves access, live transcript captured, AI results generated",
      "tags": ["consultation", "passkey", "transcription", "ai"],
      "steps": [
        {
          "order": 1,
          "screen": "consultation.patient",
          "description": "Patient opens consultation page, sees DecryptRequest",
          "checks": ["Doctor name and requested record types shown"]
        },
        {
          "order": 2,
          "screen": "consultation.patient",
          "description": "Patient approves with passkey (WebAuthn verification)",
          "checks": ["Passkey dialog shown", "usePasskey().verify() succeeds"]
        },
        {
          "order": 3,
          "screen": "consultation.patient",
          "description": "CreFeed animates CRE workflow steps (provider-decryption)",
          "checks": ["Steps progress from pending → done"]
        },
        {
          "order": 4,
          "screen": "consultation.patient",
          "description": "LiveTranscript starts — patient speaks, AssemblyAI transcribes",
          "checks": ["Mic permission granted", "Transcript entries appear"]
        },
        {
          "order": 5,
          "screen": "consultation.patient",
          "description": "Transcript completes, AiResults tab shows SOAP note, codes, interactions",
          "checks": ["All 4 result tabs populated"]
        }
      ]
    },
    {
      "id": "consultation-session-provider",
      "name": "Provider Consultation Session",
      "trigger": "navigation",
      "priority": "critical",
      "module": "consultation",
      "outcome": "Provider views patient data, captures transcript, gets AI analysis, can edit with AI chat",
      "tags": ["consultation", "provider", "transcription", "ai"],
      "steps": [
        {
          "order": 1,
          "screen": "consultation.provider",
          "description": "Provider opens consultation, sees decrypted patient vitals and LiveTranscript",
          "checks": ["Patient data card shows vitals", "Mic controls visible"]
        },
        {
          "order": 2,
          "screen": "consultation.provider",
          "description": "Provider records consultation or uses Demo mode",
          "checks": ["Transcript entries accumulate"]
        },
        {
          "order": 3,
          "endpoint": "cre.workflow-trigger",
          "description": "Provider clicks 'End Consultation', triggers consultation-processing workflow",
          "checks": ["POST /api/cre/consultation-processing with transcript"]
        },
        {
          "order": 4,
          "screen": "consultation.provider",
          "description": "CreFeed shows processing steps, results phase loads with AI Results + AI Editor tabs",
          "checks": ["SOAP note generated", "AI chat available"]
        },
        {
          "order": 5,
          "screen": "consultation.provider",
          "description": "Provider uses AI Editor to refine notes via Claude Service streaming",
          "checks": ["Chat messages stream correctly"]
        }
      ]
    },
    {
      "id": "data-marketplace-opt-in",
      "name": "Patient Opts Into Data Marketplace",
      "trigger": "user_action",
      "priority": "medium",
      "module": "patient",
      "outcome": "Patient's anonymized data listed for research queries, earns KUSD",
      "tags": ["marketplace", "data", "kusd", "privacy"],
      "steps": [
        {
          "order": 1,
          "screen": "patient.records",
          "description": "Patient toggles DataMarketplace switch to opted-in",
          "checks": ["Switch toggles to on state"]
        },
        {
          "order": 2,
          "screen": "patient.records",
          "description": "Patient selects data categories (Vitals, Medications, Lab Results, Diagnoses)",
          "checks": ["Category badges toggle on/off"]
        },
        {
          "order": 3,
          "contract": "contracts.data-marketplace",
          "description": "listData() called with selected record types",
          "checks": ["DataListed event emitted"]
        },
        {
          "order": 4,
          "screen": "patient.records",
          "description": "Earnings display updates with KUSD amount",
          "checks": ["KUSD balance shown"]
        }
      ]
    },
    {
      "id": "stripe-payment-kusd-mint",
      "name": "Stripe Payment Triggers KUSD Mint",
      "trigger": "webhook",
      "priority": "high",
      "module": "payments",
      "outcome": "Successful Stripe payment triggers CRE workflow to mint equivalent KUSD tokens",
      "tags": ["stripe", "webhook", "kusd", "mint", "cre"],
      "steps": [
        {
          "order": 1,
          "endpoint": "payments.stripe-webhook",
          "description": "Stripe sends checkout.session.completed webhook",
          "checks": ["Signature verified with STRIPE_WEBHOOK_SECRET"]
        },
        {
          "order": 2,
          "endpoint": "cre.workflow-trigger",
          "description": "triggerWorkflow('payment-mint') called with amount and sessionId",
          "checks": ["Workflow triggered successfully"]
        },
        {
          "order": 3,
          "contract": "contracts.kosyn-usd",
          "description": "CRE Forwarder calls onReport with opcode 0x04, mints KUSD to recipient",
          "checks": ["KUSDMinted event emitted", "Balance updated"]
        }
      ]
    }
  ],
  "infrastructure": {
    "blockchain": [
      {
        "name": "Avalanche Fuji",
        "chainId": 43113,
        "rpc": "env:NEXT_PUBLIC_AVAX_FUJI_RPC_URL",
        "contracts": [
          {
            "name": "HealthRecordRegistry",
            "address": "0x141eE5CE87Dea8B7dCCb1640288e298c34c98984"
          },
