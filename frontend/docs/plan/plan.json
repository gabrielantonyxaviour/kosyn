          {
            "name": "DataMarketplace",
            "address": "0x5b8c4e629bcbb131220d5Fd01294bAe921482D5D"
          }
        ]
      }
    ],
    "externalAPIs": [
      {
        "name": "Claude Service",
        "baseUrl": "env:CLAUDE_SERVICE_URL",
        "auth": "X-API-Key header",
        "purpose": "App-level AI inference (streaming chat)"
      },
      {
        "name": "Stripe",
        "baseUrl": "https://api.stripe.com",
        "auth": "STRIPE_SECRET_KEY",
        "purpose": "Payment checkout sessions and webhook verification"
      },
      {
        "name": "AssemblyAI",
        "baseUrl": "https://api.assemblyai.com/v2",
        "auth": "ASSEMBLYAI_API_KEY",
        "purpose": "Realtime speech-to-text transcription tokens"
      },
      {
        "name": "Pinata (IPFS)",
        "baseUrl": "https://api.pinata.cloud",
        "auth": "PINATA_API_KEY + PINATA_SECRET_API_KEY",
        "purpose": "Encrypted health record blob storage"
      },
      {
        "name": "CRE HTTP Trigger",
        "baseUrl": "env:NEXT_PUBLIC_CRE_HTTP_TRIGGER_URL",
        "auth": "CRE native",
        "purpose": "Chainlink Runtime Environment workflow triggers"
      }
    ],
    "aiServices": [
      {
        "name": "Claude Service (Sonnet/Opus)",
        "provider": "Anthropic via Claude Service proxy",
        "purpose": "Provider AI chat, clinical note editing",
        "model": "sonnet (default), opus (complex)"
      },
      {
        "name": "Nillion nilAI (CRE TEE)",
        "provider": "Nillion network — AMD SEV-SNP + NVIDIA CC TEE enclave",
        "purpose": "Clinical analysis, SOAP notes, drug interactions — runs only inside TEE with cryptographic proof",
        "model": "google/gemma-3-27b-it"
      }
    ],
    "sharedServices": [
      {
        "name": "Thirdweb Connect",
        "purpose": "Wallet auth (in-app for patients, MetaMask for providers), gas sponsorship, contract reads"
      },
      {
        "name": "WebAuthn Passkeys",
        "purpose": "Patient identity verification for record decryption consent"
      },
      {
        "name": "CRE Forwarder",
        "purpose": "On-chain entry point for all CRE workflow results (address from CRE_FORWARDER_ADDRESS env)"
      }
    ]
  },
